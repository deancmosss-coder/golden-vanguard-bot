const { SlashCommandBuilder, PermissionsBitField, ChannelType } = require("discord.js");

module.exports = {
  data: new SlashCommandBuilder()
    .setName("permissions")
    .setDescription("Server permission manager")
    .addSubcommand(sub =>
      sub.setName("sync")
        .setDescription("Sync all channels with their category permissions")
    )
    .addSubcommand(sub =>
      sub.setName("apply")
        .setDescription("Apply permission template to all categories")
    ),

  async execute(interaction) {

    if (!interaction.member.permissions.has(PermissionsBitField.Flags.Administrator)) {
      return interaction.reply({
        content: "❌ You must be an admin to run this command.",
        ephemeral: true
      });
    }

    const guild = interaction.guild;
    const sub = interaction.options.getSubcommand();

    if (sub === "sync") {

      const channels = guild.channels.cache.filter(c => c.parentId);

      for (const channel of channels.values()) {
        try {
          await channel.lockPermissions();
        } catch (err) {
          console.log(`Failed syncing ${channel.name}`);
        }
      }

      return interaction.reply("✅ All channels synced with their category permissions.");
    }

    if (sub === "apply") {

      const categories = guild.channels.cache.filter(
        c => c.type === ChannelType.GuildCategory
      );

      const roles = {
        everyone: guild.roles.everyone,
        helldiver: guild.roles.cache.find(r => r.name === "Helldiver"),
        commander: guild.roles.cache.find(r => r.name === "Division Commander"),
        highCommand: guild.roles.cache.find(r => r.name === "High Command")
      };

      for (const category of categories.values()) {

        try {

          await category.permissionOverwrites.set([
            {
              id: roles.everyone.id,
              allow: ["ViewChannel"],
              deny: ["SendMessages"]
            },
            {
              id: roles.helldiver?.id,
              allow: ["ViewChannel", "SendMessages"]
            },
            {
              id: roles.commander?.id,
              allow: [
                "ViewChannel",
                "SendMessages",
                "ManageMessages"
              ]
            },
            {
              id: roles.highCommand?.id,
              allow: [
                "ViewChannel",
                "SendMessages",
                "ManageMessages",
                "ManageChannels"
              ]
            }
          ]);

          const children = category.children.cache;

          for (const channel of children.values()) {
            await channel.lockPermissions();
          }

        } catch (err) {
          console.log(`Permission error in ${category.name}`);
        }

      }

      return interaction.reply("✅ Permission template applied to all categories.");
    }

  }
};