const { SlashCommandBuilder, PermissionsBitField } = require("discord.js");

module.exports = {
  data: new SlashCommandBuilder()
    .setName("setup-permissions")
    .setDescription("Automatically configure server permissions"),

  async execute(interaction) {

    if (!interaction.member.permissions.has(PermissionsBitField.Flags.Administrator)) {
      return interaction.reply({ content: "You must be an admin to run this.", ephemeral: true });
    }

    const guild = interaction.guild;

    const roles = {
      highCommand: guild.roles.cache.find(r => r.name === "High Command"),
      commander: guild.roles.cache.find(r => r.name === "Division Commander"),
      helldiver: guild.roles.cache.find(r => r.name === "Helldiver"),
      recruit: guild.roles.cache.find(r => r.name === "Recruit")
    };

    const categories = guild.channels.cache.filter(c => c.type === 4); // Categories

    for (const category of categories.values()) {

      await category.permissionOverwrites.set([
        {
          id: guild.roles.everyone,
          deny: ["SendMessages"]
        },
        {
          id: roles.recruit?.id,
          allow: ["ViewChannel", "SendMessages"]
        },
        {
          id: roles.helldiver?.id,
          allow: ["ViewChannel", "SendMessages"]
        },
        {
          id: roles.commander?.id,
          allow: ["ViewChannel", "SendMessages", "ManageMessages"]
        },
        {
          id: roles.highCommand?.id,
          allow: ["Administrator"]
        }
      ]);

      const children = category.children.cache;

      for (const channel of children.values()) {
        await channel.lockPermissions(); // Sync with category
      }

    }

    await interaction.reply("✅ Permissions applied to all categories and channels.");
  }
};